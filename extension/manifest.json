{
  "manifest_version": 3,
  "name": "Parish Trainer",
  "version": "1.0.0",
  "permissions": ["activeTab", "scripting", "contextMenus", "sidePanel"],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "Parish Trainer"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ]
}
